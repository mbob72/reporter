{
  "name": "test_constructor",
  "version": "0.1.0",
  "description": "",
  "packageManager": "pnpm@7.33.7",
  "scripts": {
    "start:api": "tsx watch --tsconfig apps/report-api/tsconfig.json apps/report-api/src/main.ts",
    "start:web": "vite --config apps/report-web/vite.config.ts",
    "dev:docker": "docker compose -f docker-compose.dev.yml up --build",
    "dev:docker:attach": "docker compose -f docker-compose.dev.yml up --build -d && pnpm dev:docker:logs",
    "dev:docker:down": "docker compose -f docker-compose.dev.yml down",
    "dev:docker:logs": "docker compose -f docker-compose.dev.yml logs -f --tail=200",
    "preview:docker": "docker compose -f docker-compose.preview.yml up --build",
    "preview:docker:attach": "docker compose -f docker-compose.preview.yml up --build -d && pnpm preview:docker:logs",
    "preview:docker:down": "docker compose -f docker-compose.preview.yml down",
    "preview:docker:logs": "docker compose -f docker-compose.preview.yml logs -f --tail=200",
    "lint": "eslint --cache --max-warnings=0 --ext .ts,.tsx apps libs",
    "lint:fix": "eslint --cache --fix --max-warnings=0 --ext .ts,.tsx apps libs",
    "format": "nx format:write",
    "format:check": "nx format:check",
    "typecheck": "nx run-many -t typecheck --projects=report-api,report-web --parallel=2",
    "build": "nx run-many -t build --projects=report-api,report-web --parallel=2",
    "test": "nx run-many -t test --projects=report-web",
    "validate": "pnpm format:check && pnpm lint && pnpm typecheck && pnpm test && pnpm build",
    "test:report-api": "vitest run --config apps/report-api/vite.config.ts",
    "test:report-api:watch": "vitest --config apps/report-api/vite.config.ts",
    "test:report-web": "vitest run --config apps/report-web/vite.config.ts",
    "test:report-web:watch": "vitest --config apps/report-web/vite.config.ts",
    "storybook:report-web": "STORYBOOK_DISABLE_TELEMETRY=1 storybook dev -p 4401 -c apps/report-web/.storybook",
    "build-storybook:report-web": "STORYBOOK_DISABLE_TELEMETRY=1 storybook build -c apps/report-web/.storybook -o dist/storybook/report-web",
    "prepare": "husky install"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@storybook/addon-essentials": "^8.6.14",
    "@storybook/addon-interactions": "^8.6.14",
    "@storybook/react": "8.6.14",
    "@storybook/react-vite": "^8.6.14",
    "@testing-library/react": "^16.3.2",
    "@eslint/js": "^9.38.0",
    "@types/node": "^18.19.87",
    "@types/react": "^18.2.79",
    "@types/react-dom": "^18.2.25",
    "autoprefixer": "^10.4.19",
    "eslint": "^9.38.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.0",
    "globals": "^16.4.0",
    "husky": "^8.0.3",
    "jsdom": "^29.0.2",
    "lint-staged": "^16.2.4",
    "nx": "22.6.5",
    "postcss": "^8.4.38",
    "prettier": "^3.6.2",
    "storybook": "^8.6.14",
    "tailwindcss": "^3.4.17",
    "tsc-alias": "^1.8.16",
    "tsx": "^3.12.7",
    "typescript-eslint": "^8.46.2",
    "typescript": "^5.4.5",
    "vitest": "^0.34.6"
  },
  "dependencies": {
    "@mantine/core": "^8.3.6",
    "@mantine/form": "^8.3.6",
    "@mantine/hooks": "^8.3.6",
    "@nestjs/common": "^9.4.3",
    "@nestjs/core": "^9.4.3",
    "@nestjs/platform-express": "^9.4.3",
    "@reduxjs/toolkit": "^2.11.2",
    "@vitejs/plugin-react": "^4.2.1",
    "express": "^4.18.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-redux": "^9.2.0",
    "react-router-dom": "^7.14.1",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.1",
    "vite": "^4.5.14",
    "xlsx-populate": "^1.21.0",
    "zod": "^4.3.6"
  }
}
