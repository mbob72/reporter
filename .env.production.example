# Public domain for the service (Caddy will manage TLS automatically)
DOMAIN=reports.example.com
CADDY_EMAIL=ops@example.com

# Published images in GHCR
API_IMAGE=ghcr.io/<github-owner>/reporter-api:latest
WEB_IMAGE=ghcr.io/<github-owner>/reporter-web:latest

# API runtime
API_HOST=0.0.0.0
API_PORT=3000
API_CORS_ORIGINS=https://reports.example.com
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
JWT_ACCESS_SECRET=replace-with-strong-access-secret
JWT_REFRESH_SECRET=replace-with-strong-refresh-secret
AUTH_COOKIE_SECURE=true
AUTH_COOKIE_SAMESITE=lax

# Generated reports storage inside API container (mapped to named volume)
GENERATED_REPORTS_DIR=/var/lib/reporter/generated-reports

# Redis runtime
REDIS_HOST=redis
REDIS_PORT=6379
