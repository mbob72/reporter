{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "name": "report-api",
  "projectType": "application",
  "sourceRoot": "apps/report-api/src",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc -p apps/report-api/tsconfig.json"
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "eslint --cache --max-warnings=0 --ext .ts apps/report-api/src"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc --noEmit -p apps/report-api/tsconfig.json"
      }
    },
    "serve": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsx watch --tsconfig apps/report-api/tsconfig.json apps/report-api/src/main.ts"
      }
    }
  },
  "tags": []
}
