{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "name": "report-web",
  "projectType": "application",
  "sourceRoot": "apps/report-web/src",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/apps/report-web/dist/apps/report-web"],
      "options": {
        "command": "vite build --config apps/report-web/vite.config.ts --outDir dist/apps/report-web"
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "eslint --cache --max-warnings=0 --ext .ts,.tsx apps/report-web/src apps/report-web/vite.config.ts apps/report-web/vite.aliases.ts apps/report-web/.storybook"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc --noEmit -p apps/report-web/tsconfig.json"
      }
    },
    "serve": {
      "executor": "nx:run-commands",
      "options": {
        "command": "vite --config apps/report-web/vite.config.ts"
      }
    },
    "storybook": {
      "executor": "nx:run-commands",
      "options": {
        "command": "STORYBOOK_DISABLE_TELEMETRY=1 storybook dev -p 4401 -c apps/report-web/.storybook"
      }
    },
    "build-storybook": {
      "executor": "nx:run-commands",
      "options": {
        "command": "STORYBOOK_DISABLE_TELEMETRY=1 storybook build -c apps/report-web/.storybook -o dist/storybook/report-web"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "vitest run --config apps/report-web/vite.config.ts"
      }
    }
  },
  "tags": []
}
